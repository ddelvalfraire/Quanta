{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["DOM", "ES2022"],
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src", "vite.config.ts"]
}
